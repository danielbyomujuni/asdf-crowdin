#!/usr/bin/env bash

set -euo pipefail

GIT_REPO="https://github.com/crowdin/crowdin-cli.git"

fail() {
  echo "asdf-crowdin: $*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

checkout_version() {
  local version="$1"

  if git checkout "tags/v${version}" 2>/dev/null; then
    return 0
  fi

  if git checkout "v${version}" 2>/dev/null; then
    return 0
  fi

  if git checkout "tags/${version}" 2>/dev/null; then
    return 0
  fi

  if git checkout "${version}" 2>/dev/null; then
    return 0
  fi

  return 1
}

main() {
  local install_type="${ASDF_INSTALL_TYPE:-version}"
  local version="${ASDF_INSTALL_VERSION:?ASDF_INSTALL_VERSION is required}"
  local download_path="${ASDF_DOWNLOAD_PATH:?ASDF_DOWNLOAD_PATH is required}"
  local src_dir="${download_path}/src"

  require_cmd git
  require_cmd mkdir
  require_cmd rm

  mkdir -p "$download_path"
  rm -rf "$src_dir"

  git clone --filter=blob:none "$GIT_REPO" "$src_dir"

  cd "$src_dir"
  git fetch --tags --force

  case "$install_type" in
    version)
      checkout_version "$version" \
        || fail "unable to find git tag for version: $version"
      ;;
    ref)
      git checkout "$version" || fail "unable to checkout ref: $version"
      ;;
    *)
      fail "unsupported ASDF_INSTALL_TYPE: $install_type"
      ;;
  esac
}

main "$@"
