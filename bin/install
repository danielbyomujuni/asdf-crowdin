#!/usr/bin/env bash

set -euo pipefail

fail() {
  echo "asdf-crowdin: $*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

main() {
  local version="${ASDF_INSTALL_VERSION:?ASDF_INSTALL_VERSION is required}"
  local install_path="${ASDF_INSTALL_PATH:?ASDF_INSTALL_PATH is required}"
  local download_path="${ASDF_DOWNLOAD_PATH:?ASDF_DOWNLOAD_PATH is required}"
  local plugin_path="${ASDF_PLUGIN_PATH:-}"
  local src_dir="${download_path}/src"
  local dist_dir
  local download_script

  require_cmd find
  require_cmd chmod
  require_cmd cp
  require_cmd mkdir

  if ! command -v java >/dev/null 2>&1; then
    fail "java is required to build crowdin-cli"
  fi

  if [ ! -d "$src_dir/.git" ]; then
    if [ -z "$plugin_path" ]; then
      fail "source not downloaded and ASDF_PLUGIN_PATH is not set"
    fi

    download_script="${plugin_path}/bin/download"

    if [ ! -x "$download_script" ]; then
      fail "download script not found or not executable: $download_script"
    fi

    "$download_script"
  fi

  cd "$src_dir"

  if [ ! -x ./gradlew ]; then
    chmod +x ./gradlew
  fi

  ./gradlew --no-daemon installDist

  dist_dir="$(find build/install -mindepth 1 -maxdepth 1 -type d | head -n 1)"
  [ -n "${dist_dir:-}" ] || fail "could not find built distribution"

  mkdir -p "$install_path"
  cp -R "$dist_dir"/. "$install_path"/

  if [ ! -d "$install_path/bin" ]; then
    fail "installation completed, but no bin directory was created"
  fi

  if ! find "$install_path/bin" -maxdepth 1 -type f | grep -q .; then
    fail "installation completed, but no executable was found in bin/"
  fi

  chmod +x "$install_path"/bin/*

  echo "crowdin-cli ${version} installation was successful!"
}

main "$@"
